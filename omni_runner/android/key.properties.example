# Android Release Signing — key.properties
#
# Copy this file to key.properties and fill in your values.
# NEVER commit key.properties (already in .gitignore).
#
# ── Generate keystore ──
#
#   keytool -genkey -v \
#     -keystore ~/omni-runner-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias omni-runner \
#     -storepass YOUR_STORE_PASSWORD \
#     -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=Omni Runner, O=OmniRunner, L=Sao Paulo, C=BR"
#
# ── Fill in below ──

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=omni-runner
storeFile=/absolute/path/to/omni-runner-release.jks

# ── L01-31 — CI signing (do NOT edit this file in CI; populate secrets instead) ──
#
# In GitHub Actions, key.properties is materialised AT BUILD TIME from two
# repository secrets:
#
#   ANDROID_KEY_PROPERTIES   — the entire text content of this file with real
#                              passwords (use `printf '%s' "$contents" | gh
#                              secret set ANDROID_KEY_PROPERTIES`).
#   ANDROID_KEYSTORE_BASE64  — `base64 -w0 omnirunner-release.keystore`
#
# The release workflow (.github/workflows/release.yml) decodes both before
# invoking fastlane, then wipes them on cleanup. If either secret is missing,
# the build fails fast with the L01-31 GradleException — see the runbook at
# docs/runbooks/ANDROID_RELEASE_SIGNING_RUNBOOK.md for the rotation procedure.
#
# Local-only escape hatch (debug-signed release APK for ProGuard testing):
#
#   flutter build apk --release -PallowReleaseDebugSigning=true
#
# CI must NEVER pass that flag — the structural lint at
# tools/test_l01_31_android_signing.sh will reject any release.yml that does.
