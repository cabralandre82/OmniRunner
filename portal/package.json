{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/copy-swagger-ui.mjs",
    "build": "next build",
    "predev": "node scripts/copy-swagger-ui.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "qa:e2e": "bash scripts/qa-full.sh",
    "qa:no-money": "bash scripts/qa-no-money.sh ../omni_runner/lib",
    "postinstall": "node scripts/copy-swagger-ui.mjs",
    "security:audit": "npm audit --audit-level=critical",
    "security:audit:report": "npm audit --audit-level=high",
    "openapi:build": "tsx tools/openapi/build.ts",
    "openapi:check": "tsx tools/openapi/check-coverage.ts",
    "openapi:baseline": "tsx tools/openapi/refresh-baseline.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@sentry/nextjs": "^10.40.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@upstash/redis": "^1.36.3",
    "framer-motion": "^12.35.0",
    "next": "^14.2.15",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "swagger-ui-dist": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
