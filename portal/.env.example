# Portal — Environment Variables
#
# Copy to .env.local and fill in your values.
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Supabase — public (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — server-only (NEVER expose to browser)
# Used for admin operations (team management, coin distribution, verification)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry — error tracking (optional in dev)
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID
SENTRY_ORG=your-org
SENTRY_PROJECT=omni-runner-portal
SENTRY_AUTH_TOKEN=sntrys_...

# Test coverage (optional)
# VITEST_COVERAGE_THRESHOLD=60
