# L11-06 — npm dependency pinning defence.
#
# - save-exact=true  : `npm install <pkg>` writes the exact version to
#                      package.json (no leading ^, ~, or range). Prevents
#                      a future contributor from accidentally adding a
#                      loose range via `npm install foo`.
#
# - engine-strict=true : npm refuses to install if the declared engines
#                        in package.json don't match. Pair with a pinned
#                        `engines.node` to catch silently-changed CI runner
#                        images.
#
# - save-prefix=      : empty prefix (defence in depth for save-exact).
#                      Any `npm install -S|-D` gets no prefix prepended.
#
# Runbook: docs/runbooks/NPM_DEPENDENCY_PINNING_RUNBOOK.md
# CI:      npm run audit:npm-dependency-pinning
# Finding: docs/audit/findings/L11-06-dependencias-com-permitem-breaking-minor.md
save-exact=true
save-prefix=
engine-strict=true
