# L11-06 — npm dependency pinning defence (workspace root).
# See portal/.npmrc for per-option rationale; mirrored here for the
# top-level `npm install` that pulls tsx / lefthook / js-yaml (the audit
# toolchain). A breaking minor in `tsx` breaks every `npm run audit:*`
# script; pinning exactly keeps the guard reproducible.
#
# Runbook: docs/runbooks/NPM_DEPENDENCY_PINNING_RUNBOOK.md
save-exact=true
save-prefix=
engine-strict=true
