# Omni Runner — Environment Variables Index
#
# This monorepo has separate env files per project:
#
#   Flutter App:  omni_runner/.env.dev  /  omni_runner/.env.prod
#   Portal:       portal/.env.local
#
# Copy the respective .env.example in each folder and fill in your values.
#
# ──────────────────────────────────────────────
# Supabase CLI (used by `supabase start` / `supabase db push`)
# These are read from your shell environment, not from a file.
# Export them or add to your shell profile (~/.bashrc, ~/.zshrc).
# ──────────────────────────────────────────────

# OAuth Providers (supabase/config.toml reads from env)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_SERVICE_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Stripe (Edge Functions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PORTAL_URL=https://portal.omnirunner.app

# TrainingPeaks (Edge Functions)
TRAININGPEAKS_CLIENT_ID=
TRAININGPEAKS_CLIENT_SECRET=
TRAININGPEAKS_REDIRECT_URI=
