# Omni Runner — Environment Variables
#
# Copy to .env.dev / .env.prod and fill in your values.
# Passed to Flutter via --dart-define-from-file at build time.
#
# Usage:
#   flutter run --flavor dev  --dart-define-from-file=.env.dev
#   flutter run --flavor prod --dart-define-from-file=.env.prod

APP_ENV=dev
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
MAPTILER_API_KEY=your_maptiler_key
SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID

# Strava Integration (OAuth flow for activity import)
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Google Sign-In (native ID-token flow)
# Get from Firebase Console → Authentication → Sign-in method → Google → Web client ID
# OR from GCP Console → Credentials → OAuth 2.0 Client IDs → Web client
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# OAuth Providers (used by supabase/config.toml)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_SERVICE_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Stripe (Edge Function: create-checkout-session, webhook handler)
# See DECISAO 049
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PORTAL_URL=https://portal.omnirunner.app
