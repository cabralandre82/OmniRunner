# Environment files with secrets
.env
.env.local
.env.dev
.env.prod

# IDE
.idea/

# Large binary archives
*.tar
*.zip
*.apk

# Generated FIT test artifacts (tools/test_fit_generation.js output)
tools/*.fit

# Firebase credentials (contains API keys)
omni_runner/android/app/google-services.json
omni_runner/ios/Runner/GoogleService-Info.plist

# Flutter / Dart build artifacts
omni_runner/.dart_tool/
omni_runner/build/
omni_runner/.flutter-plugins
omni_runner/.flutter-plugins-dependencies
omni_runner/.packages
# L11-14 — pubspec.lock IS committed for application packages.
# Flutter docs: https://dart.dev/tools/pub/glossary#lockfile —
# committing the lockfile is the recommended path for apps so every
# CI run, every dev box, and every release bundle resolves to the
# same transitive dependency tree. A drifting lockfile would let
# supply-chain risks (compromised transitive package versions)
# slip in silently between releases.
# Keep this file tracked; do NOT add it to the ignore list again.
# omni_runner/pubspec.lock  ← intentionally NOT ignored
# Generated Drift files are tracked (required for compilation)
# Other .g.dart files are regenerated by build_runner in CI

# Android
omni_runner/android/.gradle/
omni_runner/android/app/build/
omni_runner/android/local.properties
omni_runner/android/key.properties
omni_runner/android/*.keystore

# iOS
omni_runner/ios/Pods/
omni_runner/ios/.symlinks/

# Root (commitlint, lefthook)
node_modules/

# Portal (Next.js)
portal/node_modules/
portal/.next/
portal/.env.local
portal/coverage/

# Flutter test coverage
omni_runner/coverage/

# Supabase local
supabase/.temp/

# OS
.DS_Store
Thumbs.db
.env.supabase
