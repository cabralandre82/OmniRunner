# Environment files with secrets
.env
.env.local
.env.dev
.env.prod

# IDE
.idea/

# Large binary archives
*.tar
*.zip
*.apk

# Firebase credentials (contains API keys)
omni_runner/android/app/google-services.json
omni_runner/ios/Runner/GoogleService-Info.plist

# Flutter / Dart build artifacts
omni_runner/.dart_tool/
omni_runner/build/
omni_runner/.flutter-plugins
omni_runner/.flutter-plugins-dependencies
omni_runner/.packages
omni_runner/pubspec.lock
# Generated Drift files are tracked (required for compilation)
# Other .g.dart files are regenerated by build_runner in CI

# Android
omni_runner/android/.gradle/
omni_runner/android/app/build/
omni_runner/android/local.properties
omni_runner/android/key.properties
omni_runner/android/*.keystore

# iOS
omni_runner/ios/Pods/
omni_runner/ios/.symlinks/

# Root (commitlint, lefthook)
node_modules/

# Portal (Next.js)
portal/node_modules/
portal/.next/
portal/.env.local
portal/coverage/

# Flutter test coverage
omni_runner/coverage/

# Supabase local
supabase/.temp/

# OS
.DS_Store
Thumbs.db
.env.supabase
